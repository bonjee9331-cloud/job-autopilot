# Job Autopilot environment variables.
# Copy this file to .env.local for local dev, and add the same keys to
# Netlify (Site configuration > Environment variables) for production.

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="Job Autopilot"
# Set to false once Supabase + a job source are configured.
NEXT_PUBLIC_DEMO_MODE=true
NODE_ENV=development

# ---------- Supabase ----------
# From Supabase project settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
# NEVER expose this to the frontend. Server side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---------- LLM brains ----------
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
# Which provider runs first and which runs the critique pass.
PRIMARY_LLM=openai
SECONDARY_LLM=anthropic
# Set to 'single' to skip the critique pass and save tokens.
BRAIN_MODE=dual
# Model overrides. Leave blank to use sensible defaults in lib/llm.js.
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_VERSION=2023-06-01
LLM_TIMEOUT_MS=30000

# ---------- Job sources ----------
# Comma separated list. Valid values... adzuna, jooble.
JOB_SOURCES=adzuna,jooble

# Adzuna... https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble... https://jooble.org/api/about
JOOBLE_API_KEY=

# Ingestion knobs.
JOB_MAX_DAYS_OLD=7
JOB_SALARY_MIN=70000

# ---------- Security ----------
# Required in production to protect /api/jobs/sync and /api/followups/run.
JOB_SYNC_API_KEY=
FOLLOWUP_RUN_API_KEY=
